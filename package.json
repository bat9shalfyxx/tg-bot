{
  "name": "tg-bot",
  "version": "1.0.0",
  "description": "tg-bot (as pet-project)",
  "license": "ISC",
  "author": "bat9shalfyxx",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --no-warnings src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=deploy/index.js",

    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",

    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "check:ci": "biome ci src/",

    "prepare": "npm run check:fix && npm run test && npm run build",
    
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "grammy": "^1.42.0",
    "openai": "^6.35.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
